{
  "name": "@appstrate/code-review",
  "version": "1.0.0",
  "type": "agent",
  "schemaVersion": "1.0",
  "displayName": "Code Review",
  "description": "Reviews pull requests, challenges developers with questions, and unblocks when answered",
  "timeout": 300,
  "dependencies": {
    "providers": {
      "@appstrate/github": "^1.0.0"
    },
    "tools": {
      "@appstrate/output": "^1.0.0",
      "@appstrate/set-state": "^1.0.0"
    }
  },
  "providersConfiguration": {
    "@appstrate/github": {
      "scopes": ["repo"]
    }
  },
  "input": {
    "schema": {
      "type": "object",
      "properties": {
        "repoOwner": {
          "type": "string",
          "description": "Repository owner"
        },
        "repoName": {
          "type": "string",
          "description": "Repository name"
        },
        "repoFullName": {
          "type": "string",
          "description": "Full repository name (owner/name)"
        },
        "repoDefaultBranch": {
          "type": "string",
          "description": "Default branch name"
        },
        "prNumber": {
          "type": "number",
          "description": "Pull request number"
        },
        "prTitle": {
          "type": "string",
          "description": "Pull request title"
        },
        "prBody": {
          "type": "string",
          "description": "Pull request description"
        },
        "prAuthor": {
          "type": "string",
          "description": "Pull request author username"
        },
        "prBase": {
          "type": "string",
          "description": "Base branch name"
        },
        "prHead": {
          "type": "string",
          "description": "Head branch name"
        },
        "prHeadSha": {
          "type": "string",
          "description": "Head commit SHA"
        },
        "prUrl": {
          "type": "string",
          "description": "Pull request URL"
        },
        "prDraft": {
          "type": "boolean",
          "description": "Whether the PR is a draft"
        },
        "changedFiles": {
          "type": "string",
          "description": "Newline-separated list of changed file paths"
        },
        "triggerEvent": {
          "type": "string",
          "description": "GitHub event that triggered this run (pull_request or issue_comment)"
        },
        "comments": {
          "type": "string",
          "description": "PR comments formatted as [author @ date]\\nbody, separated by ---"
        },
        "triggerCommentAuthor": {
          "type": "string",
          "description": "Author of the comment that triggered this run (issue_comment only)"
        },
        "triggerCommentBody": {
          "type": "string",
          "description": "Body of the comment that triggered this run (issue_comment only)"
        }
      },
      "required": ["repoOwner", "repoName", "prNumber"]
    }
  },
  "output": {
    "schema": {
      "type": "object",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail", "warning"]
        },
        "summary": {
          "type": "string",
          "description": "Markdown summary of the review status"
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "line": { "type": "number" },
              "level": { "type": "string", "enum": ["error", "warning", "notice"] },
              "title": { "type": "string" },
              "message": { "type": "string" }
            },
            "required": ["path", "line", "level", "message"]
          }
        }
      },
      "required": ["verdict", "summary", "findings"]
    }
  }
}
